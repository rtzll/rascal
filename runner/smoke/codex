#!/usr/bin/env bash
set -euo pipefail

output_path=""
resume_session=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    exec)
      shift
      ;;
    resume)
      shift
      if [[ $# -gt 0 ]]; then
        resume_session="$1"
        shift
      fi
      ;;
    -o)
      shift
      if [[ $# -gt 0 ]]; then
        output_path="$1"
        shift
      fi
      ;;
    --json|--dangerously-bypass-approvals-and-sandbox|--skip-git-repo-check|-)
      shift
      ;;
    *)
      shift
      ;;
  esac
done

instructions="$(cat)"
session_id="${resume_session:-smoke-session-001}"
session_root="${CODEX_HOME:-/rascal-meta/codex}/sessions/2026/03"
session_path="${session_root}/smoke-session.jsonl"

if [[ -n "${GH_TOKEN:-}" ]]; then
  printf 'GH_TOKEN should not be present in container env\n' >&2
  exit 1
fi
if [[ -z "${GH_TOKEN_FILE:-}" || ! -f "${GH_TOKEN_FILE}" ]]; then
  printf 'GH_TOKEN_FILE missing or unreadable\n' >&2
  exit 1
fi
if [[ -z "${CODEX_AUTH_FILE:-}" || ! -f "${CODEX_AUTH_FILE}" ]]; then
  printf 'CODEX_AUTH_FILE missing or unreadable\n' >&2
  exit 1
fi

mkdir -p "$(dirname "${output_path:-/rascal-meta/agent_output.txt}")" "$session_root"

if [[ -f README.md ]]; then
  {
    printf '\n'
    printf 'smoke codex change\n'
  } >> README.md
else
  printf 'smoke codex change\n' > SMOKE.txt
fi

cat > /rascal-meta/commit_message.txt <<'EOF'
test(smoke): exercise docker runner
EOF

if [[ -n "$output_path" ]]; then
  printf 'smoke codex completed\n' > "$output_path"
fi

cat > "$session_path" <<EOF
{"type":"session_meta","payload":{"id":"$session_id"}}
{"type":"turn","payload":{"instructions_length":${#instructions}}}
EOF

printf '{"type":"message","text":"smoke codex ran"}\n'
