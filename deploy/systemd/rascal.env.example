RASCAL_LISTEN_ADDR=:8080
RASCAL_DATA_DIR=/var/lib/rascal
RASCAL_STATE_PATH=/var/lib/rascal/state.db
RASCAL_API_TOKEN=replace-me
RASCAL_GITHUB_TOKEN=replace-me
RASCAL_GITHUB_WEBHOOK_SECRET=replace-me
RASCAL_RUNNER_MODE=docker
# Optional: set RASCAL_AGENT_RUNTIME=codex to override the default runtime.
# Set explicit runner images per runtime.
RASCAL_RUNNER_IMAGE_GOOSE_CODEX=rascal-runner-goose-codex:latest
RASCAL_RUNNER_IMAGE_CODEX=rascal-runner-codex:latest
RASCAL_RUNNER_IMAGE_PI=rascal-runner-pi:latest
RASCAL_RUNNER_MAX_ATTEMPTS=1
RASCAL_TASK_SESSION_MODE=all
RASCAL_TASK_SESSION_ROOT=/var/lib/rascal/agent-sessions
RASCAL_TASK_SESSION_TTL_DAYS=14
