RASCAL_LISTEN_ADDR=:8080
RASCAL_DATA_DIR=/var/lib/rascal
RASCAL_STATE_PATH=/var/lib/rascal/state.db
RASCAL_API_TOKEN=replace-me
RASCAL_GITHUB_TOKEN=replace-me
RASCAL_GITHUB_WEBHOOK_SECRET=replace-me
RASCAL_RUNNER_MODE=docker
RASCAL_AGENT_BACKEND=goose
# Set explicit runner images per backend. RASCAL_RUNNER_IMAGE is legacy-only.
RASCAL_RUNNER_IMAGE_GOOSE=rascal-runner-goose:latest
RASCAL_RUNNER_IMAGE_CODEX=rascal-runner-codex:latest
RASCAL_RUNNER_MAX_ATTEMPTS=1
RASCAL_AGENT_SESSION_MODE=all
RASCAL_AGENT_SESSION_ROOT=/var/lib/rascal/agent-sessions
RASCAL_AGENT_SESSION_TTL_DAYS=14
