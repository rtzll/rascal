RASCAL_LISTEN_ADDR=:8080
RASCAL_DATA_DIR=/var/lib/rascal
RASCAL_STATE_PATH=/var/lib/rascal/state.db
RASCAL_API_TOKEN=replace-me
RASCAL_GITHUB_TOKEN=replace-me
RASCAL_GITHUB_WEBHOOK_SECRET=replace-me
RASCAL_RUNNER_MODE=docker
RASCAL_RUNNER_IMAGE=rascal-runner:latest
RASCAL_RUNNER_MAX_ATTEMPTS=1
RASCAL_GOOSE_SESSION_MODE=all
RASCAL_GOOSE_SESSION_ROOT=/var/lib/rascal/goose-sessions
RASCAL_GOOSE_SESSION_TTL_DAYS=14
RASCAL_RUNNER_EGRESS_MODE=safe-default
# Comma-separated domains/CIDRs used only when RASCAL_RUNNER_EGRESS_MODE=allowlist.
# RASCAL_RUNNER_EGRESS_ALLOWLIST=github.com,api.openai.com,140.82.112.0/20
RASCAL_CODEX_AUTH_PATH=/etc/rascal/codex_auth.json
